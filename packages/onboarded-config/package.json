{
  "name": "@schema-ide/onboarded-config",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "onboarded-config": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./dist/cli.js",
      "default": "./src/cli.ts"
    },
    "./workspace-config": {
      "types": "./src/workspace-config.ts",
      "import": "./dist/workspace-config.js",
      "default": "./src/workspace-config.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:bundle": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/bundle/onboarded-config.cjs --log-level=warning --log-override:empty-import-meta=silent --log-override:require-resolve-not-external=silent",
    "pretest": "pnpm run build",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@schema-ide/cli": "workspace:*",
    "@schema-ide/core": "workspace:*",
    "@schema-ide/schema-algebra": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "0.27.7",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
